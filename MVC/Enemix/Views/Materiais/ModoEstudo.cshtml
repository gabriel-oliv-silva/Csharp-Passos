@model Enemix.Models.Dtos.PagedResult<TopicoEstudo>
@{
    var areaStr = ViewBag.Area.ToString().ToLower();
    ViewData["Title"] = "Modo Estudo";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold text-@areaStr"><i class="bi bi-journal-richtext"></i> Pílulas de Estudo</h3>
        <a href="@Url.Action("EscolhaModo", new { area = (int)ViewBag.Area })" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left"></i> Voltar
        </a>
    </div>

    <!-- Filtros e Pesquisa -->
    <div class="card card-premium mb-4 p-3 border-2 theme-@areaStr">
        <form method="get" class="row g-2 align-items-center">
            <input type="hidden" name="area" value="@((int)ViewBag.Area)"/>
            <div class="col-md-6">
                <div class="input-group">
                    <span class="input-group-text bg-@areaStr border-0"><i class="bi bi-search"></i></span>
                    <input type="text" name="search" value="@Context.Request.Query["search"]" class="form-control"
                           placeholder="Buscar por título..."/>
                </div>
            </div>
            <div class="col-md-4">
                <select name="sort" class="form-select">
                    <option value="desc">Mais Recentes</option>
                    <option value="asc">Mais Antigos</option>
                </select>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn bg-@areaStr w-100 fw-bold">Filtrar</button>
            </div>
        </form>
    </div>

    <!-- Grid de Cards -->
    <div class="row g-4">
        @foreach (var item in Model.Items)
        {
            // Define a cor baseada na área
            var areaStri = item.AreaConhecimento.ToString().ToLower();

            <div class="col-md-6 col-lg-4 fade-in-up">
                <div class="card card-premium h-100 btn-abrir-modal" 
                     style="cursor: pointer;"
                     data-id="@item.Id"
                     data-titulo="@item.Titulo"
                     data-imagem="@item.ImagemUrl"
                     data-area="@((int)item.AreaConhecimento)"
                     data-descricao="@item.DescricaoHtml">

                    <div class="overflow-hidden" style="height: 200px; background: #eee;">
                        @if (!string.IsNullOrEmpty(item.ImagemUrl))
                        {
                            <img src="@item.ImagemUrl" class="card-img-top w-100 h-100 object-fit-cover" alt="@item.Titulo">
                        }
                        else
                        {
                            <div class="w-100 h-100 d-flex align-items-center justify-content-center bg-@areaStri bg-opacity-10">
                                <i class="bi bi-image display-1 text-@areaStri opacity-50"></i>
                            </div>
                        }
                    </div>
                    <div class="card-body">
                        <span class="badge bg-@areaStri mb-2">@item.AreaConhecimento</span>
                        <h5 class="card-title fw-bold">@item.Titulo</h5>
                    </div>
                </div>
            </div>
        }
    </div>    
</div>

<!-- Modal Flutuante de Estudo -->
<div class="modal fade" id="modalEstudo" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header modal-header-area">
                <h4 class="modal-title fw-bold" id="modalTitulo">Título da Pílula</h4>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                <img id="modalImagem" src="" class="img-fluid rounded mb-4"
                     style="display:none; max-height: 300px; object-fit: cover;"/>
                <div id="modalConteudo" class="lead text-muted lh-lg"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-salvar" data-bs-dismiss="modal">Entendi!</button>
            </div>
        </div>
    </div>
</div>