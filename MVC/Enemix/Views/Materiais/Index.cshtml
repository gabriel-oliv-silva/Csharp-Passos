@{
    ViewData["Title"] = "Dashboard ENEM";
}

<div class="container py-5 dashboard-grid">
    <div class="text-center mb-5 fade-in-up">
        <h1 class="display-4 fw-bold">Bem-vindo ao <span class="text-warning">Enemix</span></h1>
        <p class="lead text-muted">Escolha sua área de conhecimento e comece a dominar o ENEM.</p>
    </div>

    <!-- Grid Moderno 2x2 (ou 1x4 em mobile) -->
    <div class="row g-4 justify-content-center">
        @{ int index = 0; }
        @foreach (var area in Enum.GetValues(typeof(AreaConhecimento)).Cast<AreaConhecimento>())
        {
            var areaStr = area.ToString();
            var icones = new Dictionary<AreaConhecimento, string> {
                { AreaConhecimento.Linguagens, "bi-chat-quote-fill" },
                { AreaConhecimento.Humanas, "bi-globe-americas" },
                { AreaConhecimento.Natureza, "bi-droplet-half" },
                { AreaConhecimento.Matematica, "bi-calculator-fill" }
            };

            var delayClass = $"delay-{index + 1}"; // Usa os delays do seu CSS (delay-1, delay-2...)

            <div class="col-12 col-sm-6 col-lg-5 col-xl-4 fade-in-up @delayClass">
                <a href="@Url.Action("EscolhaModo", new { area = (int)area })" class="text-decoration-none d-block h-100">
                    <div class="card card-premium h-100 dashboard-area-card border-start border-4 theme-@areaStr.ToLower()">
                        
                        <!-- Ícone de Marca d'água (Background) -->
                        <i class="bi @icones[area] dashboard-watermark text-@areaStr.ToLower()"></i>
                        
                        <div class="card-body d-flex flex-column justify-content-center p-4 p-md-5 position-relative" style="z-index: 1;">
                            <div class="mb-3">
                                <i class="bi @icones[area] display-4 text-@areaStr.ToLower()"></i>
                            </div>
                            <h3 class="fw-bold card-title mb-2">@areaStr</h3>
                            <p class="card-text text-muted mb-4">Teorias, pílulas e simulados exclusivos para dominar essa área.</p>
                            <div class="mt-auto">
                                <span class="btn btn-sm rounded-pill px-4 bg-@areaStr.ToLower() text-white fw-bold shadow-sm">
                                    Acessar <i class="bi bi-arrow-right"></i>
                                </span>
                            </div>
                        </div>
                    </div>
                </a>
            </div>
            index++;
        }
    </div>
</div>