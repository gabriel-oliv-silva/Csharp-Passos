@model AreaConhecimento
@{
    var areaStr = Model.ToString().ToLower();
    ViewData["Title"] = $"Escolha o Modo - {Model.ToString()}";
}

<div class="container py-5">
    <h2 class="text-center fw-bold mb-5 text-@areaStr">
        <i class="bi bi-bookmark-star-fill"></i> Área: @ViewBag.Area
    </h2>
    
    <div class="row g-4 justify-content-center">
        <!-- Card Modo Estudo -->
        <div class="col-md-5 fade-in-up delay-1">
            <a href="@Url.Action("ModoEstudo", new { area = (int)Model})" class="text-decoration-none">
                <div class="card card-premium h-100 border-top-4 border-4 theme-@areaStr">
                    <div class="card-body d-flex flex-column align-items-center justify-content-center p-5 text-center">
                        <div class="rounded-circle bg-@areaStr bg-opacity-10 p-4 mb-4">
                            <i class="bi bi-journal-richtext display-1 text-white"></i>
                        </div>
                        <h3 class="fw-bold">Modo Estudo</h3>
                        <p class="text-muted">Pílulas teóricas rápidas e diretas ao ponto para fixação de conteúdo.</p>
                        <span class="btn bg-@areaStr text-white mt-auto fw-bold rounded-pill px-4">
                            Estudar Agora <i class="bi bi-arrow-right"></i>
                        </span>
                    </div>
                </div>
            </a>
        </div>

        <!-- Card Modo Simulado -->
        <div class="col-md-5 fade-in-up delay-2">
            <a href="@Url.Action("ModoSimulado", new { area = (int)Model })" class="text-decoration-none">
                <div class="card card-premium h-100 border-top-4 border-4 theme-@areaStr">
                    <div class="card-body d-flex flex-column align-items-center justify-content-center p-5 text-center">
                        <div class="rounded-circle bg-@areaStr bg-opacity-10 p-4 mb-4">
                            <i class="bi bi-pencil-square display-1 text-white"></i>
                        </div>
                        <h3 class="fw-bold">Modo Simulado</h3>
                        <p class="text-muted">Questões extraídas de provas reais e materiais enviados pelos professores.</p>
                        <span class="btn bg-@areaStr text-white mt-auto fw-bold rounded-pill px-4">
                            Fazer Simulado <i class="bi bi-lightning-charge-fill"></i>
                        </span>
                    </div>
                </div>
            </a>
        </div>
    </div>
</div>