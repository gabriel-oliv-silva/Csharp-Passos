@model Enemix.Models.MaterialEstudo
@{
    var areaStr = ViewBag.Area.ToString().ToLower();
    var questoes = Model.Questoes.ToList();
    ViewData["Title"] = Model.Titulo;
}

<div class="container-fluid px-4 py-4 simulado-container">
    <!-- Cabeçalho Fixo -->
    <div class="row mb-4 align-items-center">
        <div class="col-md-4">
            <a asp-action="ModoSimulado" asp-route-area="@((int)ViewBag.Area)" class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-arrow-left"></i> Voltar aos Simulados
            </a>
        </div>
        <div class="col-md-4 text-center">
            <h4 class="fw-bold mb-0 text-@areaStr"><i class="bi bi-lightning-charge-fill"></i> @Model.Titulo</h4>
        </div>
        <div class="col-md-4 text-end">
            <span class="badge bg-@areaStr fs-6 px-3 py-2">
                <span id="questoesRespondidas">0</span> / @questoes.Count Respondidas
            </span>
        </div>
    </div>

    <div class="row g-4">
        <!-- Coluna Esquerda: Navegação de Questões (Sidebar) -->
        <div class="col-lg-2 col-md-3 order-2 order-lg-1">
            <div class="list-group shadow-sm" id="questoes-nav">
                @for (int i = 0; i < questoes.Count; i++)
                {
                    <button type="button" class="list-group-item list-group-item-action d-flex justify-content-center align-items-center py-3 mb-2 rounded border-0 questao-nav-item" 
                            data-questao-index="@i" onclick="irParaQuestao(@i)">
                        <span class="fw-bold">@(i + 1)</span>
                    </button>
                }
            </div>
        </div>

        <!-- Coluna Direita: Área da Questão -->
        <div class="col-lg-10 col-md-9 order-1 order-lg-2">
            @for (int i = 0; i < questoes.Count; i++)
            {
                var q = questoes[i];
                <div class="card card-premium mb-4 questao-panel" data-questao-index="@i" style="display: none;">
                    <div class="card-header bg-transparent border-0 pt-4 px-4">
                        <span class="badge bg-secondary fs-6 mb-2">Questão @(i + 1)</span>
                        <div class="fs-5 lh-lg fw-normal text-justify">@Html.Raw(q.Enunciado.Replace("\n", "<br/>"))</div>
                    </div>
                    
                    <div class="card-body px-4 pb-4">
                        <div class="list-group alternativas-container">
                            <!-- Alternativa A -->
                            <label class="list-group-item alternativas-item d-flex align-items-start py-3 mb-2 rounded shadow-sm" data-letra="A">
                                <div class="me-3 mt-1">
                                    <span class="badge letra-badge bg-@areaStr text-white fw-bold px-3 py-2">A</span>
                                </div>
                                <div class="fs-6 fw-normal">@Html.Raw(q.AlternativaA?.Replace("\n", "<br/>"))</div>
                            </label>

                            <!-- Alternativa B -->
                            <label class="list-group-item alternativas-item d-flex align-items-start py-3 mb-2 rounded shadow-sm" data-letra="B">
                                <div class="me-3 mt-1">
                                    <span class="badge letra-badge bg-@areaStr text-white fw-bold px-3 py-2">B</span>
                                </div>
                                <div class="fs-6 fw-normal">@Html.Raw(q.AlternativaB?.Replace("\n", "<br/>"))</div>
                            </label>

                            <!-- Alternativa C -->
                            <label class="list-group-item alternativas-item d-flex align-items-start py-3 mb-2 rounded shadow-sm" data-letra="C">
                                <div class="me-3 mt-1">
                                    <span class="badge letra-badge bg-@areaStr text-white fw-bold px-3 py-2">C</span>
                                </div>
                                <div class="fs-6 fw-normal">@Html.Raw(q.AlternativaC?.Replace("\n", "<br/>"))</div>
                            </label>

                            <!-- Alternativa D -->
                            <label class="list-group-item alternativas-item d-flex align-items-start py-3 mb-2 rounded shadow-sm" data-letra="D">
                                <div class="me-3 mt-1">
                                    <span class="badge letra-badge bg-@areaStr text-white fw-bold px-3 py-2">D</span>
                                </div>
                                <div class="fs-6 fw-normal">@Html.Raw(q.AlternativaD?.Replace("\n", "<br/>"))</div>
                            </label>

                            <!-- Alternativa E -->
                            <label class="list-group-item alternativas-item d-flex align-items-start py-3 mb-2 rounded shadow-sm" data-letra="E">
                                <div class="me-3 mt-1">
                                    <span class="badge letra-badge bg-@areaStr text-white fw-bold px-3 py-2">E</span>
                                </div>
                                <div class="fs-6 fw-normal">@Html.Raw(q.AlternativaE?.Replace("\n", "<br/>"))</div>
                            </label>
                        </div>

                        <!-- Resolução (Escondida por padrão) -->
                        <div class="resolucao-box mt-4 p-4 rounded border-start border-4 d-none" style="border-color: var(--enem-@areaStr) !important; background: rgba(var(--bs-tertiary-rgb), 0.3);">
                            <h6 class="fw-bold text-@areaStr mb-2"><i class="bi bi-lightbulb-fill"></i> Resolução da Questão</h6>
                            <p class="mb-0 text-muted">@Html.Raw(q.Resolucao?.Replace("\n", "<br/>"))</p>
                        </div>
                    </div>
                </div>
            }

            <!-- Botões de Navegação Inferiores (Mobile) -->
            <div class="d-flex justify-content-between mt-3">
                <button id="btnAnterior" class="btn btn-outline-secondary" onclick="questaoAnterior()"><i class="bi bi-arrow-left"></i> Anterior</button>
                <button id="btnProxima" class="btn bg-@areaStr text-white" onclick="proximaQuestao()">Próxima <i class="bi bi-arrow-right"></i></button>
            </div>
        </div>
    </div>
</div>

    <script>
        // Dados injetados pelo Razor para o JS
        const simuladoId = '@Model.Id';
        const totalQuestoes = @questoes.Count;
        const respostasCorretas = @Html.Raw(Json.Serialize(questoes.Select(q => new { id = q.Id.ToString(), correta = q.AlternativaCorreta })));
        
        let questaoAtual = 0;
        let respostasUsuario = {};

        // 1. INICIALIZAÇÃO
        document.addEventListener('DOMContentLoaded', () => {
            // Carrega respostas salvas no localStorage
            const salvo = localStorage.getItem(`enemix_sim_${simuladoId}`);
            if (salvo) respostasUsuario = JSON.parse(salvo);

            aplicarEstadoInicial();
            irParaQuestao(0); // Começa na primeira
        });

        function aplicarEstadoInicial() {
            respostasCorretas.forEach((q, index) => {
                const panel = document.querySelector(`.questao-panel[data-questao-index="${index}"]`);
                const alternativaSelecionada = respostasUsuario[q.id];

                if (alternativaSelecionada) {
                    // Marca visualmente a alternativa salva
                    const itemSelecionado = panel.querySelector(`.alternativas-item[data-letra="${alternativaSelecionada}"]`);
                    marcarAlternativa(itemSelecionado, alternativaSelecionada, q.correta, true);
                    
                    // Pinta o número da sidebar
                    document.querySelector(`.questao-nav-item[data-questao-index="${index}"]`).classList.add('active-questao');
                }
            });
            atualizarContador();
        }

        // 2. NAVEGAÇÃO
        function irParaQuestao(index) {
            if (index < 0 || index >= totalQuestoes) return;
            questaoAtual = index;

            document.querySelectorAll('.questao-panel').forEach(p => p.style.display = 'none');
            document.querySelectorAll('.questao-nav-item').forEach(n => n.classList.remove('border-@areaStr', 'fw-bold'));

            document.querySelector(`.questao-panel[data-questao-index="${index}"]`).style.display = 'block';
            const navItem = document.querySelector(`.questao-nav-item[data-questao-index="${index}"]`);
            navItem.classList.add('border-@areaStr', 'fw-bold');

            // Scroll para o topo da questão no mobile
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        function proximaQuestao(){ irParaQuestao(questaoAtual + 1)}
        function questaoAnterior(){irParaQuestao(questaoAtual - 1)}

        // 3. CLIQUE NAS ALTERNATIVAS
        document.querySelectorAll('.alternativas-item').forEach(item => {
            item.addEventListener('click', function() {
                const panel = this.closest('.questao-panel');
                const index = parseInt(panel.getAttribute('data-questao-index'));
                const letra = this.getAttribute('data-letra');
                const questaoInfo = respostasCorretas[index];

                // Impede troca se já respondeu
                if (respostasUsuario[questaoInfo.id]) return;

                // Salva no objeto e no localStorage
                respostasUsuario[questaoInfo.id] = letra;
                localStorage.setItem(`enemix_sim_${simuladoId}`, JSON.stringify(respostasUsuario));

                // Aplica visual
                marcarAlternativa(this, letra, questaoInfo.correta, false);
                
                // Marca na sidebar
                document.querySelector(`.questao-nav-item[data-questao-index="${index}"]`).classList.add('active-questao');
                
                atualizarContador();
                verificarConclusao();
            });
        });

        function marcarAlternativa(elementoClicado, letraEscolhida, letraCerta, isLoad) {
            const panel = elementoClicado.closest('.questao-panel');
            const todasAlternativas = panel.querySelectorAll('.alternativas-item');
            
            // Desativa todas
            todasAlternativas.forEach(a => {
                a.classList.remove('selecionada', 'correta', 'errada');
                a.style.pointerEvents = 'none'; // Trava todas
            });

            // Verifica acerto/erro
            const acertou = letraEscolhida === letraCerta;
            
            if (acertou) {
                elementoClicado.classList.add('correta');
            } else {
                elementoClicado.classList.add('errada');
                // Mostra a correta
                panel.querySelector(`.alternativas-item[data-letra="${letraCerta}"]`).classList.add('correta');
            }

            // Mostra a resolução com animação se existir
            const resolucao = panel.querySelector('.resolucao-box');
            if (resolucao.innerText.trim().length > 0) {
                setTimeout(() => resolucao.classList.remove('d-none'), 300);
            }

            // Dispara Toast apenas se não for carregamento da página
            if (!isLoad) {
                if (acertou) showToast('Muito bem! Resposta correta.', 'success');
                else showToast('Ops! Resposta incorreta.', 'danger');
            }
        }

        function atualizarContador() {
            document.getElementById('questoesRespondidas').innerText = Object.keys(respostasUsuario).length;
        }

        function verificarConclusao() {
            if (Object.keys(respostasUsuario).length === totalQuestoes) {
                // Salva na lista de completos
                let completos = JSON.parse(localStorage.getItem('enemix_completed_simulados') || '[]');
                if (!completos.includes(simuladoId)) {
                    completos.push(simuladoId);
                    localStorage.setItem('enemix_completed_simulados', JSON.stringify(completos));
                    showToast('Parabéns! Você finalizou este simulado inteiro.', 'warning');
                }
            }
        }
    </script>
