@model Enemix.Models.Dtos.PagedResult<Enemix.Models.MaterialEstudo>
@{
    var areaStr = ViewBag.Area.ToString().ToLower();
    ViewData["Title"] = "Modo Simulado";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold text-@areaStr">
            <i class="bi bi-pencil-square"></i> Bancada de Simulados
        </h3>
        <a href="@Url.Action("EscolhaModo", new { area = (int)ViewBag.Area })" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left"></i> Voltar
        </a>
    </div>

    <!-- Filtros e Pesquisa -->
    <div class="card card-premium mb-4 p-3 border-2 theme-@areaStr">
        <form method="get" class="row g-2 align-items-center">
            <input type="hidden" name="area" value="@((int)ViewBag.Area)"/>
            <div class="col-md-6">
                <div class="input-group">
                    <span class="input-group-text bg-@areaStr border-0 text-white"><i class="bi bi-search"></i></span>
                    <input type="text" name="search" value="@Context.Request.Query["search"]" class="form-control"
                           placeholder="Buscar por título do simulado..."/>
                </div>
            </div>
            <div class="col-md-4">
                <select name="sort" class="form-select">
                    <option value="titulo_asc">Título (A-Z)</option>
                    <option value="titulo_desc">Título (Z-A)</option>
                </select>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn bg-@areaStr text-white w-100 fw-bold">Filtrar</button>
            </div>
        </form>
    </div>

    <!-- Grid de Simulados -->
    @if (!Model.Items.Any())
    {
        <div class="text-center py-5 text-muted fade-in-up">
            <i class="bi bi-inbox display-1"></i>
            <p class="mt-3 fs-5">Nenhum simulado encontrado para esta área.</p>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var item in Model.Items)
            {
                var qtdQuestoes = item.Questoes?.Count ?? 0;

                <div class="col-md-6 col-lg-4 fade-in-up" data-simulado-id="@item.Id">
                    <div class="card card-premium h-100 border-top-4 border-4 theme-@areaStr position-relative">
                        <div class="card-body d-flex flex-column">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <span class="badge bg-@areaStr fs-6">@item.AreaConhecimento.ToString()</span>
                                <div class="rounded-circle bg-@areaStr bg-opacity-10 p-2">
                                    <i class="bi bi-file-earmark-text-fill fs-4 text-@areaStr"></i>
                                </div>
                            </div>

                            <h5 class="card-title fw-bold mb-4 flex-grow-1">@item.Titulo</h5>

                            <div class="d-flex justify-content-between align-items-center border-top pt-3 mt-auto">
                                <span class="text-muted small">
                                    <i class="bi bi-collection-fill me-1"></i> 
                                    <strong>@qtdQuestoes</strong> questões
                                </span>

                                <!-- BOTÃO ALTERADO: Agora chama a função JS do Modal -->
                                <button type="button"
                                        class="btn btn-sm bg-@areaStr text-white rounded-pill px-3 fw-bold"
                                        onclick='abrirModalTeoriaSimulado("@item.Id", "@item.Titulo.Replace("\"", "\\\"")", @Json.Serialize(item.ConteudoTeorico ?? "<p class='text-muted fst-italic'>Este simulado não possui teoria anexada, vá direto para as questões!</p>"), @((int)item.AreaConhecimento))'>
                                    Estudar <i class="bi bi-book-fill"></i>
                                </button>
                            </div>

                            <!-- Check Verde de Conclusão -->
                            <div class="simulado-check-badge d-none position-absolute bottom-0 end-0 p-3">
                                <i class="bi bi-check-circle-fill text-success fs-2"></i>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<!-- ==========================================
     MODAL DE TEORIA DO SIMULADO
     ========================================== -->
<div class="modal fade" id="modalTeoriaSimulado" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header modal-header-area">
                <h4 class="modal-title fw-bold" id="modalTeoriaTitulo">Teoria do Simulado</h4>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                <!-- Aqui o HTML do PDF é injetado com segurança -->
                <div id="modalTeoriaConteudo" class="lead lh-lg"></div>
            </div>
            <div class="modal-footer d-flex justify-content-between">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
                    Fechar
                </button>
                <!-- Botão que leva para a página de Questões -->
                <a id="btnIrParaQuestoes" href="#" class="btn btn-salvar btn-lg px-5">
                    Ir para as Questões <i class="bi bi-arrow-right-circle-fill"></i>
                </a>
            </div>
        </div>
    </div>
</div>

<script>
    // 1. Lógica do Check Verde de Conclusão
    document.addEventListener('DOMContentLoaded', () => {
        const completedIds = JSON.parse(localStorage.getItem('enemix_completed_simulados') || '[]');
        document.querySelectorAll('[data-simulado-id]').forEach(card => {
            const id = card.getAttribute('data-simulado-id');
            if (completedIds.includes(id)) {
                card.querySelector('.simulado-check-badge').classList.remove('d-none');
            }
        });
    });

    // 2. Lógica para abrir o Modal de Teoria (Similar ao do TopicoEstudo)
    function abrirModalTeoriaSimulado(id, titulo, teoriaHtml, areaId) {
        const modal = document.getElementById('modalTeoriaSimulado');

        // Mapeamento de cores
        const classes = {1: 'linguagens', 2: 'humanas', 3: 'natureza', 4: 'matematica'};
        const areaClass = classes[areaId] || 'linguagens';

        // Aplica classes dinâmicas ao Modal
        modal.querySelector('.modal-header').className = `modal-header modal-header-area bg-${areaClass} text-white`;
        modal.querySelector('.btn-close').className = 'btn-close btn-close-white';
        modal.querySelector('.modal-footer').className = `modal-footer d-flex justify-content-between border-0 bg-${areaClass} bg-opacity-10`;
        modal.querySelector('.btn-salvar').className = `btn btn-salvar btn-lg px-5 bg-${areaClass} text-white fw-bold`;

        // Preenche dados (O innerText para o título e innerHTML para a teoria renderizar as tags)
        document.getElementById('modalTeoriaTitulo').innerText = titulo;
        document.getElementById('modalTeoriaConteudo').innerHTML = teoriaHtml;

        // Configura o link do botão de ir para as questões
        document.getElementById('btnIrParaQuestoes').href = `/Materiais/RealizarSimulado?id=${id}`;

        // Abre o modal
        new bootstrap.Modal(modal).show();
    }
</script>
