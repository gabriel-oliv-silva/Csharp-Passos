@model Enemix.Models.Dtos.PagedResult<Enemix.Models.MaterialEstudo>
@{
    var areaStr = ViewBag.Area.ToString().ToLower();
    ViewData["Title"] = "Modo Simulado";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold text-@areaStr">
            <i class="bi bi-pencil-square"></i> Bancada de Simulados
        </h3>
        <a href="@Url.Action("EscolhaModo", new { area = (int)ViewBag.Area })" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left"></i> Voltar
        </a>
    </div>

    <!-- Filtros e Pesquisa (Mesmo estilo do Modo Estudo) -->
    <div class="card card-premium mb-4 p-3 border-2 theme-@areaStr">
        <form method="get" class="row g-2 align-items-center">
            <input type="hidden" name="area" value="@((int)ViewBag.Area)" />
            <div class="col-md-6">
                <div class="input-group">
                    <span class="input-group-text bg-@areaStr text-white border-0"><i class="bi bi-search"></i></span>
                    <input type="text" name="search" value="@Context.Request.Query["search"]" class="form-control" placeholder="Buscar por título do simulado..." />
                </div>
            </div>
            <div class="col-md-4">
                <select name="sort" class="form-select">
                    <option value="titulo_asc">Título (A-Z)</option>
                    <option value="titulo_desc">Título (Z-A)</option>
                </select>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn bg-@areaStr text-white w-100 fw-bold">Filtrar</button>
            </div>
        </form>
    </div>

    <!-- Grid de Simulados -->
    @if (!Model.Items.Any())
    {
        <div class="text-center py-5 text-muted fade-in-up">
            <i class="bi bi-inbox display-1"></i>
            <p class="mt-3 fs-5">Nenhum simulado encontrado para esta área.</p>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var item in Model.Items)
            {
                var qtdQuestoes = item.Questoes?.Count ?? 0;
                
                <div class="col-md-6 col-lg-4 fade-in-up">
                    <div class="card card-premium h-100 border-top-4 border-4 theme-@areaStr">
                        <div class="card-body d-flex flex-column">
                            <!-- Cabeçalho do Card -->
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <span class="badge bg-@areaStr fs-6">@item.AreaConhecimento.ToString()</span>
                                <div class="rounded-circle bg-@areaStr bg-opacity-10 p-2">
                                    <i class="bi bi-file-earmark-text-fill fs-4 text-@areaStr"></i>
                                </div>
                            </div>

                            <!-- Corpo -->
                            <h5 class="card-title fw-bold text-dark mb-4 flex-grow-1">@item.Titulo</h5>

                            <!-- Rodapé do Card -->
                            <div class="d-flex justify-content-between align-items-center border-top pt-3 mt-auto">
                                <span class="text-muted small">
                                    <i class="bi bi-collection-fill me-1"></i> 
                                    <strong class="text-dark">@qtdQuestoes</strong> questões
                                </span>
                                <a href="#" class="btn btn-sm bg-@areaStr text-white rounded-pill px-3 fw-bold">
                                    Iniciar <i class="bi bi-play-fill"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Paginação Simples (Opcional, apenas indicadores) -->
        <div class="d-flex justify-content-center mt-5">
            <nav>
                <ul class="pagination">
                    @if (Model.HasPrevious)
                    {
                        <li class="page-item">
                            <a class="page-link text-@areaStr" href="?area=@((int)ViewBag.Area)&page=@(Model.PageNumber - 1)">
                                <i class="bi bi-chevron-left"></i>
                            </a>
                        </li>
                    }
                    
                    <li class="page-item active"><span class="page-link bg-@areaStr border-@areaStr">@Model.PageNumber</span></li>
                    
                    @if (Model.HasNext)
                    {
                        <li class="page-item">
                            <a class="page-link text-@areaStr" href="?area=@((int)ViewBag.Area)&page=@(Model.PageNumber + 1)">
                                <i class="bi bi-chevron-right"></i>
                            </a>
                        </li>
                    }
                </ul>
            </nav>
        </div>
    }
</div>